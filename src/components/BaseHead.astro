---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import type { ImageMetadata } from "astro";
import FallbackImage from "../assets/scale.png";
import {
  BUSINESS_ADDRESS,
  BUSINESS_CITY,
  BUSINESS_COUNTRY,
  BUSINESS_DESCRIPTION,
  BUSINESS_EMAIL,
  BUSINESS_NAME,
  BUSINESS_PHONE,
  BUSINESS_SOCIAL_LINKS,
  DEFAULT_SEO_KEYWORDS,
  SITE_LANGUAGE,
  SITE_LOCALE,
  SITE_TITLE,
  SITE_URL,
} from "../consts";
import "../styles/global.css";

type JsonLd = Record<string, unknown>;

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata | string;
  type?: "website" | "article";
  keywords?: string[];
  noindex?: boolean;
  canonical?: string | URL;
  structuredData?: JsonLd | JsonLd[];
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

const {
  title,
  description,
  image = FallbackImage,
  type = "website",
  keywords = [],
  noindex = false,
  canonical,
  structuredData = [],
  publishedTime,
  modifiedTime,
  author = BUSINESS_NAME,
} = Astro.props;

const site = Astro.site ?? new URL(SITE_URL);
const canonicalURL = canonical
  ? new URL(canonical, site)
  : new URL(Astro.url.pathname, site);

const imageSource = typeof image === "string" ? image : image.src;
const ogImage = new URL(imageSource, site).toString();

const dedupedKeywords = [...new Set([...DEFAULT_SEO_KEYWORDS, ...keywords])];
const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";

const organizationSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  "@id": `${SITE_URL}/#organization`,
  name: BUSINESS_NAME,
  description: BUSINESS_DESCRIPTION,
  url: SITE_URL,
  telephone: BUSINESS_PHONE,
  email: BUSINESS_EMAIL,
  sameAs: BUSINESS_SOCIAL_LINKS,
  areaServed: [
    {
      "@type": "City",
      name: BUSINESS_CITY,
    },
    {
      "@type": "Country",
      name: BUSINESS_COUNTRY,
    },
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: BUSINESS_ADDRESS,
    addressLocality: BUSINESS_CITY,
    addressCountry: BUSINESS_COUNTRY,
  },
};

const websiteSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  name: SITE_TITLE,
  url: SITE_URL,
  inLanguage: SITE_LANGUAGE,
  publisher: {
    "@id": `${SITE_URL}/#organization`,
  },
};

const pageSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  url: canonicalURL.toString(),
  inLanguage: SITE_LANGUAGE,
};

const customStructuredData = Array.isArray(structuredData)
  ? structuredData
  : [structuredData];

const structuredDataJson = JSON.stringify([
  organizationSchema,
  websiteSchema,
  pageSchema,
  ...customStructuredData,
]);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" hreflang="es-ec" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />
<meta name="generator" content={Astro.generator} />
<meta name="author" content={author} />
<meta name="robots" content={robots} />
<meta name="googlebot" content={robots} />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="theme-color" content="#163b5e" />
<meta name="format-detection" content="telephone=no" />

<!-- Font preloads -->
<link
  rel="preload"
  href="/fonts/atkinson-regular.woff"
  as="font"
  type="font/woff"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/atkinson-bold.woff"
  as="font"
  type="font/woff"
  crossorigin
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{
  dedupedKeywords.length > 0 && (
    <meta name="keywords" content={dedupedKeywords.join(", ")} />
  )
}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL.toString()} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={SITE_LOCALE} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={title} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL.toString()} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{
  type === "article" && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )
}
{
  type === "article" && modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime} />
  )
}

<script type="application/ld+json" set:html={structuredDataJson} />
