---
export const prerender = false;

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE, SITE_URL } from "../../consts";

const { slug } = Astro.params;

const services = await import(`../../content/services/${slug}.md`);
const { Content, frontmatter } = services;

const pageTitle = `${frontmatter.title} | ${SITE_TITLE}`;
const pageDescription = frontmatter.description;
const pageImage = frontmatter.image || undefined;
const pageKeywords = [
  `${frontmatter.title.toLowerCase()} quito`,
  "asesoria legal quito",
  "abogado en quito",
];
const serviceStructuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: frontmatter.title,
  name: `${frontmatter.title} en Quito`,
  description: pageDescription,
  provider: {
    "@id": `${SITE_URL}/#organization`,
  },
  areaServed: "Quito, Ecuador",
  url: `${SITE_URL}/services/${slug}`,
};
const serviceBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: SITE_URL,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Servicios",
      item: `${SITE_URL}/services`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: frontmatter.title,
      item: `${SITE_URL}/services/${slug}`,
    },
  ],
};
---

<html lang="es">
  <head>
    <BaseHead
      title={pageTitle}
      description={pageDescription}
      image={pageImage}
      keywords={pageKeywords}
      structuredData={[serviceStructuredData, serviceBreadcrumb]}
    />
  </head>
  <body>
    <Header />

    <main class="container">
      <h1>{frontmatter.title}</h1>
      <p>{frontmatter.description}</p>
      <div class="contenido">
        <Content />
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  .contenido {
    margin-top: 1.5rem;
    line-height: 1.6;
  }
</style>
